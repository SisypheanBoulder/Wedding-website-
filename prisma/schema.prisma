generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Guest {
  id           Int       @id @default(autoincrement())
  firstName    String
  lastName     String
  phone        String?
  email        String?
  tableId      Int?
  seatNumber   Int?
  plusOne      Boolean   @default(false)
  plusOneName  String?
  dietaryNotes       String?
  invitedToTea       Boolean   @default(false)
  invitedToCeremony  Boolean   @default(false)
  invitedToReception Boolean   @default(true)
  rsvpStatus         String    @default("pending") // pending | confirmed | declined
  rsvpDate           DateTime?
  notes              String?
  table              Table?    @relation(fields: [tableId], references: [id])
}

model Table {
  id       Int     @id @default(autoincrement())
  name     String
  shape    String  // "round" | "rectangle"
  seats    Int
  x        Float
  y        Float
  width    Float
  height   Float
  rotation Float   @default(0)
  guests   Guest[]
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}
